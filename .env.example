# Groq API - free tier at https://console.groq.com
# Llama 3 70B, fast inference, no GPU needed on your end
GROQ_API_KEY=your_groq_api_key_here

# Jenkins connection - get your API token from:
# Jenkins Dashboard > Your User > Configure > API Token > Add new token
JENKINS_URL=http://localhost:8080
JENKINS_USER=admin
JENKINS_TOKEN=your_api_token_here
